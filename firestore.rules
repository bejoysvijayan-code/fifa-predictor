rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow any authenticated user to create predictions (needed for admin import)
    // Users can only update their own predictions
    match /predictions/{predId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /polls/{pollId} {
      // Any authenticated user can read polls
      allow read: if request.auth != null;
      // Only authenticated users can create/update/delete (admin action)
      allow write: if request.auth != null;
    }

    match /pollVotes/{voteId} {
      // Any authenticated user can read votes (for results display)
      allow read: if request.auth != null;
      // A user can only create a vote for themselves
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Votes cannot be changed or deleted once cast
      allow update, delete: if false;
    }
  }
}
