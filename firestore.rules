rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow any authenticated user to create predictions (needed for admin import)
    // Users can only update their own predictions
    match /predictions/{predId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /groups/{groupId} {
      // Public groups are readable without auth (for Discover page)
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /polls/{pollId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /pollVotes/{voteId} {
      // Any authenticated user can read votes (for results display)
      allow read: if request.auth != null;
      // A user can only create a vote for themselves
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Votes cannot be changed once cast, but can be deleted (e.g. when admin deletes a poll)
      allow update: if false;
      allow delete: if request.auth != null;
    }

    match /activity/{actId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /houses/{houseId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
